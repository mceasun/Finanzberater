    let quizQuestions = [];
    let currentIndex = 0;
    let score = 0;
    let selectedForMulti = [];
    let userResults = [];

    function shuffle(array) {
      const arr = [...array];
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function prepareQuestions() {
      quizQuestions = shuffle(questions).map(q => {
        const shuffledAnswers = q.answers.map((text, index) => ({ text, originalIndex: index }));
        const mixedAnswers = shuffle(shuffledAnswers);
        const newCorrect = mixedAnswers
          .map((a, idx) => q.correct.includes(a.originalIndex) ? idx : null)
          .filter(v => v !== null);

        return {
          ...q,
          shuffledAnswers: mixedAnswers,
          shuffledCorrect: newCorrect
        };
      });
    }

    function startQuiz() {
      prepareQuestions();
      currentIndex = 0;
      score = 0;
      selectedForMulti = [];
      userResults = [];

      document.getElementById("startScreen").classList.add("hidden");
      document.getElementById("summaryScreen").classList.add("hidden");
      document.getElementById("quizScreen").classList.remove("hidden");
      document.getElementById("totalQuestions").textContent = quizQuestions.length;

      renderQuestion();
    }

    function renderQuestion() {
      const q = quizQuestions[currentIndex];
      selectedForMulti = [];

      document.getElementById("currentQuestionNr").textContent = currentIndex + 1;
      document.getElementById("scoreNow").textContent = score;
      document.getElementById("topicName").textContent = q.topic;
      document.getElementById("questionBox").textContent = q.question;
      document.getElementById("feedbackBox").innerHTML = "";
      document.getElementById("nextBtn").classList.add("hidden");

      const progress = ((currentIndex) / quizQuestions.length) * 100;
      document.getElementById("progressBar").style.width = progress + "%";

      const answersBox = document.getElementById("answersBox");
      answersBox.innerHTML = "";

      q.shuffledAnswers.forEach((answer, idx) => {
        const btn = document.createElement("button");
        btn.className = "answer-btn";
        btn.textContent = answer.text;

        if (q.type === "single") {
          btn.onclick = () => handleSingleAnswer(idx);
        } else {
          btn.onclick = () => toggleMultiAnswer(btn, idx);
        }

        answersBox.appendChild(btn);
      });

      if (q.type === "multi") {
        const checkBtn = document.createElement("button");
        checkBtn.className = "main-btn";
        checkBtn.textContent = "Antwort prüfen";
        checkBtn.style.marginTop = "14px";
        checkBtn.onclick = checkMultiAnswer;
        answersBox.appendChild(checkBtn);
      }
    }

    function toggleMultiAnswer(btn, idx) {
      if (selectedForMulti.includes(idx)) {
        selectedForMulti = selectedForMulti.filter(i => i !== idx);
        btn.classList.remove("selected");
      } else {
        selectedForMulti.push(idx);
        btn.classList.add("selected");
      }
    }

    function arraysEqual(a, b) {
      const x = [...a].sort((m, n) => m - n);
      const y = [...b].sort((m, n) => m - n);
      return JSON.stringify(x) === JSON.stringify(y);
    }

    function handleSingleAnswer(selectedIndex) {
      const q = quizQuestions[currentIndex];
      const buttons = document.querySelectorAll(".answer-btn");
      buttons.forEach(btn => btn.disabled = true);

      const isCorrect = q.shuffledCorrect[0] === selectedIndex;

      buttons.forEach((btn, idx) => {
        if (q.shuffledCorrect.includes(idx)) {
          btn.classList.add("correct");
        }
        if (idx === selectedIndex && !q.shuffledCorrect.includes(idx)) {
          btn.classList.add("wrong");
        }
      });

      if (isCorrect) score++;

      userResults.push({
        question: q.question,
        topic: q.topic,
        correct: isCorrect,
        explanation: q.explanation
      });

      showFeedback(isCorrect, q.explanation);
    }

    function checkMultiAnswer() {
      const q = quizQuestions[currentIndex];
      const buttons = document.querySelectorAll(".answer-btn");
      const isCorrect = arraysEqual(selectedForMulti, q.shuffledCorrect);

      buttons.forEach((btn, idx) => {
        btn.disabled = true;
        if (q.shuffledCorrect.includes(idx)) {
          btn.classList.add("correct");
        }
        if (selectedForMulti.includes(idx) && !q.shuffledCorrect.includes(idx)) {
          btn.classList.add("wrong");
        }
      });

      if (isCorrect) score++;

      userResults.push({
        question: q.question,
        topic: q.topic,
        correct: isCorrect,
        explanation: q.explanation
      });

      showFeedback(isCorrect, q.explanation);
    }

    function showFeedback(isCorrect, explanation) {
      const box = document.getElementById("feedbackBox");
      box.innerHTML = `
        <div class="feedback ${isCorrect ? "good" : "bad"}">
          ${isCorrect ? "✅ Richtig!" : "❌ Nicht ganz."}
        </div>
        <div class="explanation"><strong>Lösungshinweis:</strong> ${explanation}</div>
      `;
      document.getElementById("scoreNow").textContent = score;
      document.getElementById("nextBtn").classList.remove("hidden");
    }

    function nextQuestion() {
      currentIndex++;
      if (currentIndex < quizQuestions.length) {
        renderQuestion();
      } else {
        showSummary();
      }
    }

    function showSummary() {
      document.getElementById("quizScreen").classList.add("hidden");
      document.getElementById("summaryScreen").classList.remove("hidden");

      const percent = Math.round((score / quizQuestions.length) * 100);
      document.getElementById("finalPercent").textContent = percent + "%";
      document.getElementById("finalScoreText").textContent = `${score} von ${quizQuestions.length} richtig`;
      document.getElementById("topicSummary").textContent = `Ritter Vorsorge: ${score}/${quizQuestions.length} richtig`;

      let tip = "";
      if (percent >= 85) {
        tip = "Sehr stark. Du bist in diesem Thema schon ziemlich sattelfest. 🛡️";
      } else if (percent >= 65) {
        tip = "Gute Basis. Schau dir die falschen Fragen nochmals gezielt an.";
      } else {
        tip = "Hier steckt noch Potenzial drin. Fokus auf Lücken, dann wird der Ritter stärker. ⚔️";
      }
      document.getElementById("studyTip").textContent = tip;

      const wrongAnswers = userResults.filter(r => !r.correct);
      const reviewSection = document.getElementById("reviewSection");
      const reviewList = document.getElementById("reviewList");

      if (wrongAnswers.length > 0) {
        reviewSection.classList.remove("hidden");
        reviewList.innerHTML = wrongAnswers.map(item => `
          <div class="review-item">
            <strong>Frage:</strong> ${item.question}
            <div><strong>Thema:</strong> ${item.topic}</div>
            <div class="small" style="margin-top: 8px;"><strong>Lösungshinweis:</strong> ${item.explanation}</div>
          </div>
        `).join("");
      } else {
        reviewSection.classList.add("hidden");
        reviewList.innerHTML = "";
      }

      document.getElementById("progressBar").style.width = "100%";
    }

    function restartQuiz() {
      startQuiz();
    }
  </script>
