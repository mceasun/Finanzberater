function AdminArea() {
  const [search, setSearch] = useState("");
  const [filter, setFilter] = useState("Alle");

  const filteredClients = useMemo(() => {
    return demoClients.filter((client) => {
      const matchesSearch = [client.name, client.id, client.businessType, client.status]
        .join(" ")
        .toLowerCase()
        .includes(search.toLowerCase());
      const matchesFilter = filter === "Alle" ? true : client.status === filter;
      return matchesSearch && matchesFilter;
    });
  }, [search, filter]);

  return (
    <div className="space-y-6">
      <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <StatCard title="Neue Fälle" value="12" icon={AlertTriangle} hint="davon 4 mit hohem Handlungsbedarf" />
        <StatCard title="In Prüfung" value="8" icon={Clock3} hint="AI-Auswertung läuft oder wurde geprüft" />
        <StatCard title="Abgeschlossen" value="21" icon={CheckCircle2} hint="bereits bearbeitet und dokumentiert" />
        <StatCard title="Terminanfragen" value="6" icon={CalendarDays} hint="neue Buchungen seit gestern" />
      </div>

      <Card className="rounded-[28px] border-0 shadow-xl">
        <CardHeader>
          <CardTitle className="text-2xl">Admin Dashboard</CardTitle>
          <CardDescription>
            Hier seht ihr alle Kundeneingaben, hochgeladenen Unterlagen und den daraus erkannten Handlungsbedarf.
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-5">
          <div className="grid gap-3 lg:grid-cols-[1fr_220px]">
            <div className="relative">
              <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground" />
              <Input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Kunde, ID, Status oder Rechtsform suchen ..." className="pl-10" />
            </div>
            <Select value={filter} onValueChange={setFilter}>
              <SelectTrigger>
                <SelectValue placeholder="Status filtern" />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="Alle">Alle</SelectItem>
                <SelectItem value="Offen">Offen</SelectItem>
                <SelectItem value="In Prüfung">In Prüfung</SelectItem>
                <SelectItem value="Abgeschlossen">Abgeschlossen</SelectItem>
              </SelectContent>
            </Select>
          </div>

          <div className="grid gap-5 xl:grid-cols-2">
            {filteredClients.map((client) => (
              <motion.div
                key={client.id}
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ duration: 0.25 }}
              >
                <Card className="rounded-3xl border border-slate-200 shadow-none">
                  <CardContent className="p-6">
                    <div className="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <div className="flex items-center gap-2">
                          <h3 className="text-xl font-semibold">{client.name}</h3>
                          <Badge variant="outline">{client.id}</Badge>
                        </div>
                        <p className="mt-1 text-sm text-muted-foreground">
                          {client.businessType} · {client.source}
                        </p>
                      </div>
                      <div className="flex flex-wrap gap-2">
                        <span className={`rounded-full border px-3 py-1 text-xs font-semibold ${statusStyles[client.status]}`}>
                          {client.status}
                        </span>
                        <span className={`rounded-full border px-3 py-1 text-xs font-semibold ${priorityStyles[client.urgency]}`}>
                          {client.urgency}
                        </span>
                      </div>
                    </div>

                    <div className="mt-5 space-y-2">
                      <div className="flex items-center justify-between text-sm">
                        <span className="text-muted-foreground">Vollständigkeit</span>
                        <span className="font-medium">{client.completion}%</span>
                      </div>
                      <Progress value={client.completion} />
                    </div>

                    <Separator className="my-5" />

                    <div>
                      <p className="mb-3 text-sm font-semibold">Erkannter Handlungsbedarf</p>
                      <div className="flex flex-wrap gap-2">
                        {client.needs.map((need) => (
                          <NeedBadge key={need} text={need} />
                        ))}
                      </div>
                    </div>

                    <div className="mt-5 grid gap-5 md:grid-cols-2">
                      <div>
                        <p className="mb-2 text-sm font-semibold">Dokumente</p>
                        <div className="space-y-2">
                          {client.documents.map((doc) => (
                            <div key={doc} className="flex items-center gap-2 rounded-xl bg-slate-50 px-3 py-2 text-sm">
                              <FileText className="h-4 w-4" />
                              {doc}
                            </div>
                          ))}
                        </div>
                      </div>

                      <div>
                        <p className="mb-2 text-sm font-semibold">Interne Notiz</p>
                        <div className="rounded-2xl bg-slate-50 p-4 text-sm leading-6 text-slate-700">
                          {client.note}
                        </div>
                      </div>
                    </div>

                    <div className="mt-5 flex flex-wrap gap-3">
                      <Button className="rounded-2xl">Fall öffnen</Button>
                      <Button variant="outline" className="rounded-2xl">Bearbeitungsstatus anpassen</Button>
                      <Button variant="ghost" className="rounded-2xl">Handlungsbedarf editieren</Button>
                    </div>
                  </CardContent>
                </Card>
              </motion.div>
            ))}
          </div>
        </CardContent>
      </Card>
    </div>
  );
}

